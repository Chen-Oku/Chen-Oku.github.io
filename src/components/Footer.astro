---
import { siteConfig } from "../config/content";
const socialLinks = siteConfig.socialLinks;
---

<!-- Footer Component -->
<section class="relative text-gray-700">
  <div
    class="container flex flex-col items-center justify-center min-h-[40px] mx-auto px-7 max-w-7xl sm:flex-row sm:min-h-[50px] bg-transparent py-4"
  >
    <a
      class="h-5 text-base group relative z-30 flex items-center space-x-1.5 text-neutral-700 dark:text-neutral-300 font-semibold"
      href="/"
    >
      <span
        class="text-xl -translate-y-0.5 group-hover:-rotate-12 group-hover:scale-[1.2] ease-in-out duration-300"
        >✦</span
      >
      <span class="-translate-y-0.5">Your Name</span>
    </a>
    <p
      class="mt-2 text-sm text-neutral-700 dark:text-neutral-300 sm:ml-4 sm:pl-4 sm:border-l sm:border-neutral-700 dark:sm:border-neutral-300 sm:mt-0"
    >
      © 2025 Your Name. All rights reserved.
    </p>
    <span
      class="inline-flex justify-center mt-2 space-x-5 sm:ml-auto sm:mt-0 sm:justify-start"
    >
      {
        socialLinks.map((item) => (
          <a
            href={item.href}
            target={item.icon === "email" ? undefined : "_blank"}
            rel={item.icon === "email" ? undefined : "noopener noreferrer"}
            class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-400 dark:hover:text-neutral-300"
          >
            <span class="sr-only">{item.label}</span>

            {item.icon === "behance" && (
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M2 5.75A3.75 3.75 0 0 1 5.75 2h12.5A3.75 3.75 0 0 1 22 5.75v12.5A3.75 3.75 0 0 1 18.25 22H5.75A3.75 3.75 0 0 1 2 18.25z"
                  stroke="currentColor"
                  stroke-width="1.6"
                />
                <path
                  d="M7 8.3h4.3c2 0 3.2 1 3.2 2.6 0 1.2-.7 2-1.8 2.3 1.4.3 2.3 1.3 2.3 2.8 0 1.9-1.5 3-3.9 3H7zm3.8 4.2c1 0 1.6-.4 1.6-1.2 0-.7-.6-1.1-1.6-1.1H9.2v2.3zm.3 4.6c1.2 0 1.9-.5 1.9-1.4s-.7-1.4-1.9-1.4H9.2v2.8zm4.6-7.9h4.6v1.2h-4.6z"
                  fill="currentColor"
                />
              </svg>
            )}

            {item.icon === "github" && (
              <svg
                class="w-5 h-5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.12 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                  clip-rule="evenodd"
                ></path>
              </svg>
            )}

            {item.icon === "linkedin" && (
              <svg
                class="w-5 h-5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M6.94 8.5H3.56V20h3.38V8.5Zm.23-3.57a1.97 1.97 0 1 0-3.94 0 1.97 1.97 0 0 0 3.94 0ZM20.44 13.4c0-3.5-1.86-5.13-4.35-5.13-2.01 0-2.91 1.1-3.41 1.88V8.5H9.3V20h3.38v-5.7c0-1.5.28-2.95 2.14-2.95 1.83 0 1.86 1.71 1.86 3.05V20h3.38v-6.6Z" />
              </svg>
            )}

            {item.icon === "email" && (
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            )}
          </a>
        ))
      }
    </span>
  </div>
</section>
