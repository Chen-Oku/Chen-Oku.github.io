---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { projectsContent, siteConfig } from "../config/content.ts";
import { getAllProjects } from "../utils/getProjects";
import { getGithubRepos } from "../utils/getGithubRepos";

const allProjects = getAllProjects();
const githubUsername =
  projectsContent.github?.username ||
  siteConfig.social.github.split("github.com/")[1] ||
  "";
const githubRepos = githubUsername
  ? await getGithubRepos(githubUsername, {
      maxRepos: projectsContent.github?.maxRepos || 6,
      featuredRepos: projectsContent.github?.featuredRepos || [],
    })
  : [];
const repoOverrides = projectsContent.github?.repoOverrides || {};
const visibleGithubRepos = githubRepos
  .map((repo) => {
    const override = (repoOverrides as Record<string, any>)[repo.name] || {};
    return {
      ...repo,
      displayTitle: override.title || repo.name,
      description: override.description ?? repo.description,
      language: override.language ?? repo.language,
      hide: override.hide === true,
    };
  })
  .filter((repo) => !repo.hide);

// Extract unique categories and tags for filters
const allCategories = ["All", ...Array.from(new Set(allProjects.map(p => p.category).filter(Boolean)))];
const allTags = Array.from(new Set(allProjects.flatMap(p => p.tags || []))).sort();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{projectsContent.meta.title}</title>
    <meta name="description" content={projectsContent.meta.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });

        // Project filtering system
        let currentCategory = "GameDev";
        let currentTags = new Set<string>();

        const projectCards = document.querySelectorAll(".project-card");
        const categoryButtons = document.querySelectorAll("[data-category-filter]");
        const tagButtons = document.querySelectorAll("[data-tag-filter]");
        const clearTagsButton = document.getElementById("clear-tags");
        const toggleTagsButton = document.getElementById("toggle-tags");
        const tagsContainer = document.getElementById("tags-container");

        // Initialize category button states (GameDev active by default)
        categoryButtons.forEach((btn) => {
          const btnCategory = btn.getAttribute("data-category-filter");
          if (btnCategory === "GameDev") {
            btn.classList.remove("bg-white", "dark:bg-neutral-800", "text-neutral-700", "dark:text-neutral-300", "border-neutral-300", "dark:border-neutral-600");
            btn.classList.add("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
          } else {
            btn.classList.remove("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
            btn.classList.add("bg-white", "dark:bg-neutral-800", "text-neutral-700", "dark:text-neutral-300", "border-neutral-300", "dark:border-neutral-600");
          }
        });

        // Apply initial filter
        filterProjects();

        // Show more/less tags functionality
        const MAX_VISIBLE_TAGS = 6;
        let tagsExpanded = false;

        function updateTagsVisibility() {
          if (!tagsContainer || !toggleTagsButton) return;
          const allTagButtons = Array.from(tagsContainer.querySelectorAll(".filter-tag"));
          const hiddenCount = allTagButtons.length - MAX_VISIBLE_TAGS;

          if (tagsExpanded) {
            allTagButtons.forEach(btn => (btn as HTMLElement).style.display = "inline-flex");
            toggleTagsButton.textContent = "Show less";
          } else {
            allTagButtons.forEach((btn, index) => {
              (btn as HTMLElement).style.display = index < MAX_VISIBLE_TAGS ? "inline-flex" : "none";
            });
            toggleTagsButton.textContent = hiddenCount > 0 ? `Show more (+${hiddenCount})` : "Show more";
          }
        }

        // Initialize tags visibility
        updateTagsVisibility();

        // Toggle tags button handler
        toggleTagsButton?.addEventListener("click", () => {
          tagsExpanded = !tagsExpanded;
          updateTagsVisibility();
        });

        // Category filter handlers
        categoryButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const category = button.getAttribute("data-category-filter");
            if (!category) return;

            categoryButtons.forEach((btn) => {
              const btnCategory = btn.getAttribute("data-category-filter");
              if (btnCategory === category) {
                btn.classList.remove("bg-white", "dark:bg-neutral-800", "text-neutral-700", "dark:text-neutral-300", "border-neutral-300", "dark:border-neutral-600");
                btn.classList.add("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
              } else {
                btn.classList.remove("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
                btn.classList.add("bg-white", "dark:bg-neutral-800", "text-neutral-700", "dark:text-neutral-300", "border-neutral-300", "dark:border-neutral-600");
              }
            });

            currentCategory = category;
            filterProjects();
          });
        });

        // Tag filter handlers
        tagButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const tag = button.getAttribute("data-tag-filter");
            if (!tag) return;

            if (currentTags.has(tag)) {
              currentTags.delete(tag);
              button.classList.remove("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
              button.classList.add("bg-white", "dark:bg-neutral-800", "text-neutral-600", "dark:text-neutral-400", "border-neutral-300", "dark:border-neutral-600");
            } else {
              currentTags.add(tag);
              button.classList.remove("bg-white", "dark:bg-neutral-800", "text-neutral-600", "dark:text-neutral-400", "border-neutral-300", "dark:border-neutral-600");
              button.classList.add("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
            }

            filterProjects();
          });
        });

        // Clear tags handler
        clearTagsButton?.addEventListener("click", () => {
          currentTags.clear();
          tagButtons.forEach((button) => {
            button.classList.remove("bg-neutral-900", "dark:bg-neutral-100", "text-white", "dark:text-neutral-900", "border-neutral-900", "dark:border-neutral-100");
            button.classList.add("bg-white", "dark:bg-neutral-800", "text-neutral-600", "dark:text-neutral-400", "border-neutral-300", "dark:border-neutral-600");
          });
          filterProjects();
        });

        // Main filtering function
        function filterProjects() {
          projectCards.forEach((card) => {
            const cardCategory = card.getAttribute("data-category") || "Uncategorized";
            const cardTags = (card.getAttribute("data-tags") || "").split(",").map(t => t.trim()).filter(t => t);

            const categoryMatch = currentCategory === "All" || cardCategory === currentCategory;
            const tagsMatch = currentTags.size === 0 || [...currentTags].every((tag: string) => cardTags.includes(tag));

            const htmlCard = card as HTMLElement;
            if (categoryMatch && tagsMatch) {
              htmlCard.style.display = "flex";
              htmlCard.style.opacity = "1";
            } else {
              htmlCard.style.display = "none";
              htmlCard.style.opacity = "0";
            }
          });
        }
      });
    </script>
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow-x: hidden;
      }
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      main {
        flex: 1;
      }
      section[class*="text-gray-700"] {
        margin: 0;
        padding: 0;
        flex-shrink: 0;
      }

      .dot-hexagon-light {
        background-image: radial-gradient(
            circle,
            #80808045 1px,
            transparent 1px
          ),
          radial-gradient(circle, #80808045 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }

      .dot-hexagon-dark {
        background-image: radial-gradient(
            circle,
            #ffffff35 1px,
            transparent 1px
          ),
          radial-gradient(circle, #ffffff35 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }
    </style>
  </head>
  <body class="bg-white dark:bg-neutral-900 transition-colors duration-300">
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div
        class="absolute inset-0 -z-10 dot-hexagon-light dark:dot-hexagon-dark"
      >
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.5)_60%,rgba(255,255,255,0.9)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(23,23,23,0.5)_60%,rgba(23,23,23,0.9)_85%,rgb(23,23,23)_100%)] -z-10"
      >
      </div>
      <div
        class="absolute left-0 right-0 top-0 -z-10 m-auto h-[1200px] w-[1200px] rounded-full bg-neutral-400 opacity-10 blur-[100px]"
      >
      </div>
    </div>

    <main class="flex-1 relative z-10">
      <Navigation />
      <section class="relative z-20 max-w-4xl mx-auto mt-20 sm:mt-32 mb-12 px-4 sm:px-7 lg:px-0">
        <div class="relative z-20 w-full mx-auto lg:mx-0">
          <h2
            class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl"
          >
            {projectsContent.title}
          </h2>
          <div
            class="mt-3 space-y-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
          >
            {
              projectsContent.descriptionParagraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))
            }
          </div>

          <!-- Category Filter Buttons -->
          <div class="flex flex-wrap gap-2 my-6">
            {allCategories.map((category) => (
              <button
                data-category-filter={category}
                class="filter-btn px-4 py-2 text-sm font-medium rounded-lg border transition-all duration-200
                  {category === 'All'
                    ? 'bg-neutral-900 dark:bg-neutral-100 text-white dark:text-neutral-900 border-neutral-900 dark:border-neutral-100'
                    : 'bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 border-neutral-300 dark:border-neutral-600 hover:border-neutral-900 dark:hover:border-neutral-100'
                  }"
              >
                {category}
              </button>
            ))}
          </div>

          <!-- Tag Filter Chips -->
          {allTags.length > 0 && (
            <div class="flex flex-wrap gap-2 my-4">
              <span class="text-sm text-neutral-500 dark:text-neutral-400 py-2">Filter by role:</span>
              <div id="tags-container" class="flex flex-wrap gap-2">
                {allTags.map((tag) => (
                  <button
                    data-tag-filter={tag}
                    class="filter-tag px-3 py-1.5 text-xs font-medium rounded-full border transition-all duration-200
                      bg-white dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 border-neutral-300 dark:border-neutral-600
                      hover:border-neutral-900 dark:hover:border-neutral-100 hover:text-neutral-900 dark:hover:text-neutral-100"
                  >
                    {tag}
                  </button>
                ))}
              </div>
              <button
                id="toggle-tags"
                class="px-3 py-1.5 text-xs font-medium rounded-full border transition-all duration-200
                  bg-neutral-100 dark:bg-neutral-700 text-neutral-600 dark:text-neutral-400 border-neutral-300 dark:border-neutral-600
                  hover:border-neutral-900 dark:hover:border-neutral-100 hover:text-neutral-900 dark:hover:text-neutral-100"
              >
                Show more
              </button>
              <button
                id="clear-tags"
                class="px-3 py-1.5 text-xs font-medium rounded-full border transition-all duration-200
                  bg-neutral-100 dark:bg-neutral-700 text-neutral-600 dark:text-neutral-400 border-neutral-300 dark:border-neutral-600
                  hover:border-neutral-900 dark:hover:border-neutral-100 hover:text-neutral-900 dark:hover:text-neutral-100"
              >
                Clear Tags
              </button>
            </div>
          )}

          <div
            id="projects-grid"
            class="z-50 grid items-stretch w-full grid-cols-1 my-8 gap-7 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3"
          >
            {
              allProjects.map((project) => (
                <a
                  href={project.href}
                  data-category={project.category || "Uncategorized"}
                  data-tags={(project.tags || []).join(",")}
                  class="project-card relative flex flex-col items-stretch duration-300 ease-out p-4 sm:p-3 md:p-7 group rounded-2xl"
                >
                  <span class="absolute inset-0 z-20 block w-full h-full duration-300 ease-out bg-transparent border border-transparent border-dashed group-hover:-translate-x-1 group-hover:-translate-y-1 group-hover:border group-hover:border-neutral-300 dark:group-hover:border-neutral-600 group-hover:border-dashed rounded-2xl group-hover:bg-white dark:group-hover:bg-neutral-950" />
                  <span class="absolute inset-0 z-10 block w-full h-full duration-300 ease-out border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:translate-x-1 group-hover:translate-y-1" />
                  <span class="relative z-30 block duration-300 ease-out group-hover:-translate-x-1 group-hover:-translate-y-1">
                    <span class="block w-full">
                      {project.video ? (
                        <video
                          src={project.video}
                          class="w-full h-auto rounded-lg aspect-[16/9] object-cover"
                          muted
                          loop
                          autoplay
                          playsinline
                        />
                      ) : (
                        <img
                          src={project.image}
                          alt={project.title}
                          class="w-full h-auto rounded-lg aspect-[16/9] object-cover"
                        />
                      )}
                    </span>
                    <span class="block w-full px-1 mt-5 mb-1 sm:mt-3">
                      <span class="flex items-center mb-0 text-base font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
                        <span>{project.title}</span>
                        <svg
                          class="group-hover:translate-x-0 group-hover:translate-y-0 -rotate-45 translate-y-1 -translate-x-1 w-2.5 h-2.5 stroke-current ml-1 transition-all ease-in-out duration-200 transform"
                          viewBox="0 0 13 15"
                        >
                          <g
                            stroke="none"
                            stroke-width="1"
                            fill="none"
                            fill-rule="evenodd"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <g
                              transform="translate(0.666667, 2.333333)"
                              stroke="currentColor"
                              stroke-width="2.4"
                            >
                              <g>
                                <polyline
                                  class="transition-all duration-200 ease-out opacity-0 delay-0 group-hover:opacity-100"
                                  points="5.33333333 0 10.8333333 5.5 5.33333333 11"
                                />
                                <line
                                  class="transition-all duration-200 ease-out transform -translate-x-1 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-hover:ml-0"
                                  x1="10.8333333"
                                  y1="5.5"
                                  x2="0.833333333"
                                  y2="5.16666667"
                                />
                              </g>
                            </g>
                          </g>
                        </svg>
                      </span>
                      <span class="text-sm text-neutral-600 dark:text-neutral-400 block line-clamp-2">
                        {project.description}
                      </span>
                      <div class="flex flex-wrap gap-1.5 mt-3">
                        {(project.tags || []).slice(0, 4).map((tag) => (
                          <span class="text-[10px] px-2 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700">
                            {tag}
                          </span>
                        ))}
                        {(project.tags || []).length > 4 && (
                          <span class="text-[10px] px-2 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700">
                            +{project.tags.length - 4}
                          </span>
                        )}
                      </div>
                    </span>
                  </span>
                </a>
              ))
            }
          </div>

          {
            visibleGithubRepos.length > 0 && (
              <div class="mt-14">
                <h3 class="text-xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-2xl">
                  GitHub Repositories
                </h3>
                <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400 sm:text-base">
                  Latest public repositories from GitHub.
                </p>

                <div class="z-50 grid items-stretch w-full grid-cols-1 my-6 gap-5 sm:grid-cols-2">
                  {visibleGithubRepos.map((repo) => (
                    <a
                      href={repo.htmlUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="relative flex flex-col items-stretch duration-300 ease-out p-4 sm:p-5 group rounded-2xl"
                    >
                      <span class="absolute inset-0 z-20 block w-full h-full duration-300 ease-out bg-transparent border border-transparent border-dashed group-hover:-translate-x-1 group-hover:-translate-y-1 group-hover:border group-hover:border-neutral-300 dark:group-hover:border-neutral-600 group-hover:border-dashed rounded-2xl group-hover:bg-white dark:group-hover:bg-neutral-950" />
                      <span class="absolute inset-0 z-10 block w-full h-full duration-300 ease-out border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:translate-x-1 group-hover:translate-y-1" />
                      <span class="relative z-30 block duration-300 ease-out group-hover:-translate-x-1 group-hover:-translate-y-1">
                        <span class="flex items-center justify-between gap-3 mb-2">
                          <span class="text-base font-semibold tracking-tight text-neutral-900 dark:text-neutral-100 truncate">
                            {repo.displayTitle}
                          </span>
                          <div class="flex items-center gap-2">
                            {
                              repo.isFeatured && (
                                <span class="text-[10px] uppercase tracking-wide px-2 py-0.5 rounded-full bg-amber-200 text-amber-900 dark:bg-amber-500/20 dark:text-amber-200">
                                  Featured
                                </span>
                              )
                            }
                            <span class="text-xs text-neutral-500 dark:text-neutral-400">
                              ★ {repo.stargazersCount}
                            </span>
                          </div>
                        </span>
                        {
                          repo.description && (
                            <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2">
                              {repo.description}
                            </p>
                          )
                        }
                        <div class="mt-4 flex flex-wrap items-center gap-2 sm:gap-3 text-xs text-neutral-500 dark:text-neutral-400">
                          {repo.language && <span>{repo.language}</span>}
                          {repo.language && <span>•</span>}
                          <span>
                            Updated {new Date(repo.updatedAt).toLocaleDateString("en-US")}
                          </span>
                        </div>
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
